{
  "name": "dennis-portfolio",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "optimize:media": "node scripts/optimize-media.mjs",
    "upscale:gallery": "node scripts/upscale-gallery.mjs",
    "deploy:contact": "wrangler deploy -c workers/contact/wrangler.toml",
    "deploy": "npm run deploy:contact && astro build && wrangler pages deploy dist --project-name=dennis-portfolio --commit-dirty=true",
    "thumbs": "node scripts/build-thumbs.mjs",
    "avif": "node scripts/build-avif.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/outfit": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.1.1",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "sharp": "^0.34.2",
    "wrangler": "^4.112.0"
  }
}
