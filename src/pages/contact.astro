---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/contact/ContactForm';
import { site } from '../lib/site';
import { copy } from '../lib/i18n';

const formDe = {
  name: 'Name',
  email: 'E-Mail',
  subject: 'Betreff',
  message: 'Nachricht',
  send: 'Nachricht senden',
  sending: 'Senden…',
  success: 'Danke — deine Nachricht ist unterwegs.',
  error: 'Senden fehlgeschlagen. Versuch’s nochmal oder schreib direkt per Mail.',
  required: 'Bitte Name, E-Mail und Nachricht ausfüllen.',
  invalidEmail: 'Bitte prüf die E-Mail-Adresse — sie sieht nicht gültig aus.',
};

const formEn = {
  name: 'Name',
  email: 'Email',
  subject: 'Subject',
  message: 'Message',
  send: 'Send message',
  sending: 'Sending…',
  success: 'Thanks — your message is on its way.',
  error: 'Couldn’t send. Try again or email me directly.',
  required: 'Please fill in name, email, and message.',
  invalidEmail: 'Please check the email address — it doesn’t look valid.',
};
---

<BaseLayout
  title={`Kontakt — ${site.name}`}
  description={`Kontakt zu ${site.name} — Art Direction, UX/UI, Branding, Video oder Product. Formular oder direkt per Mail.`}
>
  <section class="section pt-[calc(var(--nav-h)+2.5rem)]" data-block-id="contact" data-block-type="contact" data-block-source="native" data-block-label="Contact">
    <div class="wrap grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
      <div>
        <p class="section-label">
          <span data-lang="de">{copy.de.contact.label}</span>
          <span data-lang="en">{copy.en.contact.label}</span>
        </p>
        <h1 class="display mb-4 text-[clamp(2rem,5.5vw,3.4rem)] leading-[1.05]">
          <span data-lang="de">
            Lass uns <span class="gradient-text">{copy.de.contact.titleAccent}</span>
          </span>
          <span data-lang="en">
            Let's <span class="gradient-text">{copy.en.contact.titleAccent}</span>
          </span>
        </h1>
        <p class="mb-8 max-w-[42ch] text-[1.05rem] normal-case tracking-normal text-[var(--dim)]">
          <span data-lang="de" data-edit="contact.body.de">{copy.de.contact.body}</span>
          <span data-lang="en" data-edit="contact.body.en">{copy.en.contact.body}</span>
        </p>

        <div class="contact-form-shell">
          {/* client:load on purpose — before hydration a bare <form> would submit
              natively via GET and leak field values into the URL */}
          <ContactForm client:load de={formDe} en={formEn} />
        </div>
      </div>

      <aside class="relative space-y-6 overflow-hidden rounded-[28px] border border-[var(--stroke)] bg-[var(--panel)] p-7 lg:sticky lg:top-[calc(var(--nav-h)+1.25rem)]">
        <div
          aria-hidden
          class="pointer-events-none absolute -right-10 -top-10 h-40 w-40 rounded-full opacity-50"
          style="background: radial-gradient(circle, color-mix(in srgb, var(--violet) 45%, transparent), transparent 70%)"
        />
        <p class="hero-status relative !text-[0.78rem]">
          <span class="hero-status__dot" aria-hidden></span>
          <span data-lang="de">{site.availability.de}</span>
          <span data-lang="en">{site.availability.en}</span>
        </p>
        <div class="relative">
          <div class="mb-1 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-[var(--meta)]">
            <span data-lang="de">{copy.de.contact.email}</span>
            <span data-lang="en">{copy.en.contact.email}</span>
          </div>
          <!--email_off--><a class="break-all text-[1.15rem] gradient-text" href={`mailto:${site.email}`} data-edit="site.email">{site.email}</a><!--/email_off-->
        </div>
        <div class="relative">
          <div class="mb-1 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-[var(--meta)]">
            <span data-lang="de">{copy.de.contact.location}</span>
            <span data-lang="en">{copy.en.contact.location}</span>
          </div>
          <div class="normal-case tracking-normal text-[var(--text)]" data-edit="site.location">{site.location}</div>
        </div>
        <div class="relative flex flex-wrap gap-3 pt-1">
          <a class="btn" href={site.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a class="btn" href={site.links.github} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
