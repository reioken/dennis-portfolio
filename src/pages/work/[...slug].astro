---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseMedia from '../../components/work/CaseMedia';
import CaseMediaTabs from '../../components/work/CaseMediaTabs';
import CaseAdjacent from '../../components/work/CaseAdjacent.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../lib/site';
import { p } from '../../lib/paths';

export async function getStaticPaths() {
  const works = await getCollection('work');
  return works.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const all = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((w) => w.id === entry.id);
const prev = all[(idx - 1 + all.length) % all.length];
const next = all[(idx + 1) % all.length];
const asset = (src: string) => p(src.replace(/^\//, ''));

function hiAsset(sitePath: string): string | undefined {
  const clean = sitePath.replace(/^\//, '');
  const candidates = [
    clean.replace(/(\.\w+)$/, '@2x.webp'),
    clean.replace(/(\.\w+)$/, '@2x$1'),
  ];
  for (const rel of candidates) {
    if (fs.existsSync(path.join(process.cwd(), 'public', rel))) {
      return p(rel);
    }
  }
  return undefined;
}

const coverSrc = asset(data.cover);
const coverHi = hiAsset(data.cover);
const galleryOnly = data.gallery
  .map((g) => g.replace(/^\//, ''))
  .filter((g) => g !== data.cover.replace(/^\//, ''));

const images = [
  {
    src: coverSrc,
    srcHi: coverHi,
    alt: `${data.title} Cover`,
  },
  ...galleryOnly.map((g, i) => ({
    src: asset(g),
    srcHi: hiAsset(g),
    alt: `${data.title} — ${i + 1}`,
  })),
];

const surfaces = (data.surfaces ?? []).map((surface) => ({
  id: surface.id,
  labelDe: surface.labelDe,
  labelEn: surface.labelEn,
  variant: surface.variant,
  images: surface.gallery.map((g, i) => ({
    src: asset(g),
    srcHi: hiAsset(g),
    alt: `${data.title} ${surface.labelDe} — ${i + 1}`,
  })),
}));

const when = data.timeline || data.year;
const hasBody = (entry.body ?? '').replace(/<[^>]+>/g, '').trim().length > 0;
---

<BaseLayout
  title={`${data.title} — ${site.name}`}
  description={data.summary}
  ogImage={asset(data.cover)}
>
  <article class="case-page">
    <header class="case-page__intro wrap">
      <div class="case-page__main">
        <p class="case-page__eyebrow">
          <span>{data.role}</span>
          {when && (
            <>
              <span class="case-page__dot" aria-hidden="true">·</span>
              <span>{when}</span>
            </>
          )}
        </p>
        <h1 class="case-page__title">{data.title}</h1>
        <p class="case-page__summary">{data.summary}</p>
        {
          hasBody && (
            <div class="case-page__copy prose-case">
              <Content />
            </div>
          )
        }
      </div>

      <aside class="case-page__aside" aria-label="Project details">
        {
          data.stack.length > 0 && (
            <div class="case-page__block">
              <h2 class="case-page__label">Stack</h2>
              <ul class="case-page__chips">
                {data.stack.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )
        }
        {
          data.outcome && (
            <div class="case-page__block">
              <h2 class="case-page__label">
                <span data-lang="de">Ergebnis</span>
                <span data-lang="en">Outcome</span>
              </h2>
              <p class="case-page__outcome">{data.outcome}</p>
            </div>
          )
        }
      </aside>
    </header>

    {
      surfaces.length > 0 ? (
        <CaseMediaTabs client:load title={data.title} surfaces={surfaces} />
      ) : (
        <CaseMedia
          client:load
          title={data.title}
          images={images}
          coverCount={0}
          variant={entry.id === 'berry' ? 'phone' : 'desktop'}
        />
      )
    }

    <div class="wrap">
      <CaseAdjacent prev={prev} next={next} index={idx} total={all.length} />
    </div>
  </article>
</BaseLayout>
