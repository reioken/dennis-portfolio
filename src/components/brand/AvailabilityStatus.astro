---
import { site } from '../../lib/site';

interface Props {
  showLocation?: boolean;
  class?: string;
}

const { showLocation = false, class: className = '' } = Astro.props;
const { de, en } = site.availability;
---

<p class:list={['hero-status', className]}>
  <span class="hero-status__dot" aria-hidden></span>
  <span class="hero-status__body">
    <span data-lang="de" class="hero-status__lang">
      <span class="hero-status__part">{de.role}</span>
      <span class="hero-status__sep" aria-hidden>·</span>
      <span class="hero-status__part hero-status__part--nohire">{de.noHire}</span>
      <span class="hero-status__sep" aria-hidden>·</span>
      <span class="hero-status__part hero-status__part--freelance">{de.freelance}</span>
      {
        showLocation && (
          <>
            <span class="hero-status__sep" aria-hidden>·</span>
            <span class="hero-status__part">{site.location}</span>
          </>
        )
      }
    </span>
    <span data-lang="en" class="hero-status__lang">
      <span class="hero-status__part">{en.role}</span>
      <span class="hero-status__sep" aria-hidden>·</span>
      <span class="hero-status__part hero-status__part--nohire">{en.noHire}</span>
      <span class="hero-status__sep" aria-hidden>·</span>
      <span class="hero-status__part hero-status__part--freelance">{en.freelance}</span>
      {
        showLocation && (
          <>
            <span class="hero-status__sep" aria-hidden>·</span>
            <span class="hero-status__part">Mannheim/Heidelberg area</span>
          </>
        )
      }
    </span>
  </span>
</p>
