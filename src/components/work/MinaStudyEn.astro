    margin: 0 0 0.45rem;
    font-size: 1rem;
    font-weight: 800;
  }
  .mstudy__principle p {
    margin: 0;
  }
  .mstudy__principle--green { background: #59d99a; }
  .mstudy__principle--yellow { background: #ffd34e; }
