    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1.1;
  }
  .mstudy__stat span {
    font-size: 0.8rem;
    font-weight: 600;
    color: #47506a;
  }
  .mstudy__stat--coral strong { color: #ef6a5b; }
  .mstudy__stat--yellow strong { color: #e0a800; }
  .mstudy__stat--green strong { color: #17b26a; }
  .mstudy__stat--teal strong { color: #2e8b6e; }
  .mstudy__personas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .mstudy__persona {
    border-radius: 18px;
    background: #f4f5f8;
    padding: 1.2rem 1.3rem;
    font-size: 0.92rem;
  }
  .mstudy__persona--lead {
    background: #ffd34e;
  }
  .mstudy__persona h4 {
    margin: 0 0 0.6rem;
    font-size: 1.1rem;
    font-weight: 800;
  }
  .mstudy__persona h4 span {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #55503a;
  }
  .mstudy__persona p {
    margin: 0 0 0.5rem;
  }
  .mstudy__principles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .mstudy__principle {
    border-radius: 18px;
    padding: 1.1rem 1.2rem;
    font-size: 0.9rem;
  }
