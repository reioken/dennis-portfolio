  .mstudy__principle--dark { background: #2b2f36; color: #f2f4f8; }
  .mstudy__cols {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 1.75rem;
    align-items: center;
  }
  .mstudy__figure {
    margin: 0;
  }
  .mstudy__figure img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    background: #f4f5f8;
  }
  .mstudy__figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.78rem;
    color: #6a7288;
  }
  .mstudy__figure--dark figcaption {
    color: #aab2c4;
  }
  .mstudy__journey {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    counter-reset: none;
  }
  .mstudy__journey li {
    display: flex;
    gap: 0.7rem;
    background: #f4f5f8;
    border-radius: 16px;
    padding: 1rem 1.1rem;
    font-size: 0.88rem;
  }
  .mstudy__journey strong {
    display: block;
    margin-bottom: 0.25rem;
  }
  .mstudy__journey p {
    margin: 0 0 0.3rem;
  }
  .mstudy__journey-num {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 999px;
    background: #17b26a;
    color: #fff;
    font-weight: 800;
    font-size: 0.85rem;
  }
  .mstudy__pain {
    font-size: 0.8rem;
    font-weight: 600;
    color: #b4443a;
  }
  .mstudy__flow {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }
  .mstudy__flow li {
    border-radius: 999px;
    padding: 0.6rem 1.1rem;
    background: #fff;
    color: #1e2430;
    font-weight: 700;
    font-size: 0.88rem;
    text-align: center;
  }
  .mstudy__flow li.is-accent {
    background: #34d399;
    color: #0d2b1d;
  }
  @media (max-width: 760px) {
    .mstudy__band,
    .mstudy__section,
    .mstudy__panel--flush {
      padding-inline: 1.25rem;
    }
    .mstudy__band-right {
      text-align: left;
    }
    .mstudy__intro,
    .mstudy__cols {
      grid-template-columns: 1fr;
