---
/**
 * Trust-Leiste: Stationen/Arbeitgeber als ruhige Wortmarken-Reihe.
 * Bewusst Text statt Logos — keine Markenrechte-Fragen, bleibt im Site-Look.
 */
const stations = [
  { name: 'Floordirekt', note: { de: 'Art Direction · aktuell', en: 'Art direction · current' } },
  { name: 'Forever GmbH', note: { de: 'Grafik & Content', en: 'Design & content' } },
  { name: 'performio', note: { de: 'Web & Corporate', en: 'Web & corporate' } },
  { name: 'cyberWear', note: { de: 'Key Accounts (Porsche, DB)', en: 'Key accounts (Porsche, DB)' } },
  { name: 'Decathlon', note: { de: 'E-Commerce', en: 'E-commerce' } },
];
---

<div class="trustbar" role="list" aria-label="Stationen">
  <p class="trustbar__label">
    <span data-lang="de">Stationen</span>
    <span data-lang="en">Stations</span>
  </p>
  <ul class="trustbar__row">
    {
      stations.map((s) => (
        <li class="trustbar__item" role="listitem">
          <span class="trustbar__name">{s.name}</span>
          <span class="trustbar__note">
            <span data-lang="de">{s.note.de}</span>
            <span data-lang="en">{s.note.en}</span>
          </span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .trustbar {
    margin-top: 2.5rem;
    padding: 1.15rem 1.35rem;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--stroke) 85%, transparent);
    background: color-mix(in srgb, var(--panel-soft) 80%, transparent);
  }
  .trustbar__label {
    margin: 0 0 0.7rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--meta);
  }
  .trustbar__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 2.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .trustbar__item {
    display: grid;
    gap: 0.1rem;
  }
  .trustbar__name {
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    color: var(--text);
  }
  .trustbar__note {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
  }
</style>
